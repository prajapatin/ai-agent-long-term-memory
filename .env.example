# =============================================================================
# LLM Provider for LangChain Agents
# Supported: openai, groq, ollama
# =============================================================================
LLM_PROVIDER=groq

# OpenAI (required if LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-your-openai-api-key

# Groq (required if LLM_PROVIDER=groq)
GROQ_API_KEY=gsk_your-groq-api-key

# Ollama (required if LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# =============================================================================
# Hindsight Server Configuration
# =============================================================================
HINDSIGHT_API_URL=http://localhost:8888

# LLM provider for the Hindsight server itself (used inside Docker)
HINDSIGHT_LLM_PROVIDER=groq
HINDSIGHT_LLM_API_KEY=gsk_your-groq-api-key
HINDSIGHT_LLM_MODEL=llama-3.3-70b-versatile
